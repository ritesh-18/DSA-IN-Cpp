class MyQueue {
    stack<int>pushstack;
        stack<int>popstack;
public:
    MyQueue() {
        
    }
    
    void push(int x) {
        pushstack.push(x);
    }
    
    int pop() {
        if(empty()){
            return 0;
        }
        else{
            if(!popstack.empty()){
                int v=popstack.top();
                popstack.pop();
                return v;
            }
            else{
                while(!pushstack.empty()){
                    popstack.push(pushstack.top());
                    pushstack.pop();
                }
                int v=popstack.top();
                popstack.pop();
                return v;
            }
        }
        
    }
    
    int peek() {
        if(empty()){
            return 0;
        }
        else{
            if(!popstack.empty()){
                return popstack.top();
            }
            else{
                if(!pushstack.empty()){
                    while(!pushstack.empty()){
                        popstack.push(pushstack.top());
                        pushstack.pop();
                    }
                    return popstack.top();
                }
                return 0;
            }
        }
    }
    
    bool empty() {
        return pushstack.empty() && popstack.empty();
    }
};

