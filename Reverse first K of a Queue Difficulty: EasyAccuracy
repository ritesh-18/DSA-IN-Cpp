 queue<int> reverseFirstK(queue<int> q, int k) {
        // code here
        if(k > q.size()) return q;
        stack<int>st;
 
        while(k--){
            st.push(q.front());
            q.pop();
        }
        int d=q.size();
        while(!st.empty()){
            q.push(st.top());
            st.pop();
        }
        

        while(d--){
            q.push(q.front());
            q.pop();
        }
        return q;
    }
