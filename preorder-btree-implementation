#include <iostream>
using namespace std;

class Node{
    public:
  int data;
  Node *left , *right;
  Node(int d){
      this->data=d;
      left=right=nullptr;
  }
};


Node * btree(){
    int x; 
    cin>>x;
    if(x==-1)return nullptr;
    Node * temp=new Node(x);
    temp->left=btree();
    temp->right=btree();
    return temp;
}
