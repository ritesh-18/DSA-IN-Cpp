// Online C++ compiler to run C++ program online
#include <iostream>
#include<queue>
using namespace std;

class Node{
    public:
  int data;
  Node *left , *right;
  Node(int d){
      this->data=d;
      left=right=nullptr;
  }
};

int main() {
    // Write C++ code here
   int rootval, first  , second;
   queue<Node*>q;
   cout<<"Enter the root data value "<<endl;
   cin>>rootval;
   cout<<"THe root value is "<<rootval<<endl;
   Node * root=new Node(rootval);
   q.push(root);
   
   while(!q.empty()){
       Node * temp=q.front();
       q.pop();
       cout<<"Enter the left node value for parent : "<<temp->data<<endl;
       cin>>first;
       if(first !=-1){
           temp->left=new Node(first);
           q.push(temp->left);
       }
       cout<<"Enter the right node value for parent : "<<temp->data<<endl;
       cin>>second;
       if(second != -1){
           temp->right=new Node(second);
           q.push(temp->right);
       }
       
       
       
   }
   
   
   



    return 0;
}



