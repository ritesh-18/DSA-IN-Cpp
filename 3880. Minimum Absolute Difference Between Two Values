class Solution {
public:
    int minAbsoluteDifference(vector<int>& nums) {
        int minVal=INT_MAX;

        int first=-1 ,second=-1;

        for(int i=0; i<nums.size(); i++){
             if(nums[i]==1){
                first=i;
                if(second!=-1){
                minVal=min(minVal , abs(first-second));
                }
             }

             if(nums[i]==2){
                second=i;
                if(first!=-1){
                    minVal=min(minVal , abs(first-second));
                }
             }

        }
      
      return minVal==INT_MAX ?-1 :minVal;
    }
};
