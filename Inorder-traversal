  void val(Node* root , vector<int>&ans){
        if(root==nullptr)return;
        val(root->left , ans);
        ans.push_back(root->data);
        
        val(root->right , ans);

    }
    vector<int> inOrder(Node* root) {
        // code here
        vector<int>ans;
        // code here
        val(root , ans);
        return ans;
        
    }
